# Zotero Web API credentials
# Get your API key from: https://www.zotero.org/settings/keys
# Get your library ID from: https://www.zotero.org/settings/keys/new (shown as "Your userID for use in API calls")
ZOTERO_API_KEY=your_api_key_here
ZOTERO_LIBRARY_ID=your_numeric_library_id
ZOTERO_LIBRARY_TYPE=user

# Anthropic API key (required for Ask/summarise features)
# Get yours from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
